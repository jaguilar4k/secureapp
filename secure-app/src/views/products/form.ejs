<%- include('../partials/header', { titulo: titulo }) %>

<div class="page-header">
  <h2><%= titulo %></h2>
  <a href="/productos" class="btn btn-secondary">← Volver</a>
</div>

<% if (errors && errors.length) { %>
  <div class="alert alert-danger">
    <ul class="mb-0">
      <% errors.forEach(e => { %><li><%= e.msg %></li><% }) %>
    </ul>
  </div>
<% } %>

<div class="form-card">
  <form
    action="/productos/<%= producto.id ? producto.id + '/editar' : 'nuevo' %>"
    method="POST"
    novalidate
  >
    <!-- RS-03: Token CSRF -->
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

    <div class="form-row">
      <div class="form-group">
        <label for="codigo">Código <span class="required">*</span></label>
        <input
          type="text"
          id="codigo"
          name="codigo"
          class="form-control"
          value="<%= producto.codigo || '' %>"
          placeholder="Ej: PROD-001"
          maxlength="20"
          pattern="[A-Za-z0-9\-_]{1,20}"
          required
        >
        <small class="form-hint">Alfanumérico, guiones y guión bajo. Máx 20 caracteres.</small>
      </div>

      <div class="form-group">
        <label for="nombre">Nombre <span class="required">*</span></label>
        <input
          type="text"
          id="nombre"
          name="nombre"
          class="form-control"
          value="<%= producto.nombre || '' %>"
          maxlength="100"
          required
        >
      </div>
    </div>

    <div class="form-group">
      <label for="descripcion">Descripción</label>
      <textarea
        id="descripcion"
        name="descripcion"
        class="form-control"
        rows="3"
        maxlength="500"
      ><%= producto.descripcion || '' %></textarea>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label for="cantidad">Cantidad <span class="required">*</span></label>
        <input
          type="number"
          id="cantidad"
          name="cantidad"
          class="form-control"
          value="<%= producto.cantidad !== undefined ? producto.cantidad : '' %>"
          min="0"
          step="1"
          required
        >
      </div>

      <div class="form-group">
        <label for="precio">Precio (₡) <span class="required">*</span></label>
        <input
          type="number"
          id="precio"
          name="precio"
          class="form-control"
          value="<%= producto.precio !== undefined ? producto.precio : '' %>"
          min="0"
          step="0.01"
          required
        >
      </div>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary">
        <%= producto.id ? 'Guardar Cambios' : 'Crear Producto' %>
      </button>
      <a href="/productos" class="btn btn-secondary">Cancelar</a>
    </div>
  </form>
</div>

<script>
// Validación adicional en el frontend (RF-03)
document.querySelector('form').addEventListener('submit', function(e) {
  const codigo   = document.getElementById('codigo').value.trim();
  const nombre   = document.getElementById('nombre').value.trim();
  const cantidad = parseInt(document.getElementById('cantidad').value);
  const precio   = parseFloat(document.getElementById('precio').value);

  const errors = [];
  if (!/^[A-Za-z0-9\-_]{1,20}$/.test(codigo)) errors.push('Código inválido.');
  if (!nombre) errors.push('Nombre requerido.');
  if (isNaN(cantidad) || cantidad < 0) errors.push('Cantidad inválida.');
  if (isNaN(precio) || precio < 0) errors.push('Precio inválido.');

  if (errors.length) {
    e.preventDefault();
    // RS-02: No usar innerHTML con datos del usuario
    const div = document.querySelector('.alert-danger') || document.createElement('div');
    div.className = 'alert alert-danger';
    div.textContent = errors.join(' | ');
    document.querySelector('.form-card').prepend(div);
  }
});
</script>

<%- include('../partials/footer') %>
